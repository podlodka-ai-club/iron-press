# Required. Personal Linear API key with read/write scope for the Linear workspace.
LINEAR_API_KEY=lin_api_...

# Optional. Anthropic API key for the Claude Agent SDK.
#
# Leave unset if you're signed in to Claude Code (`claude login`). The Agent SDK
# picks up those OAuth credentials automatically and bills against your
# Pro/Max/Team subscription. Set a key here only to use pay-as-you-go API
# credits instead of the subscription.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional. Workspace root. Defaults to the parent of the .claude/ directory that contains this orchestrator.
# WORKSPACE_ROOT=

# Optional. Hard ceiling for total USD spend per run. --max-budget-usd overrides.
# Note: when using subscription auth, `costUsd` is Anthropic-equivalent pricing, not a real charge.
# MAX_RUN_USD=50
