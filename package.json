{
  "name": "orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Production orchestrator for the agent pipeline, driven by the Claude Agent SDK.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "do": "./dist/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "do": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui": "tsx ui/server.ts",
    "ui:typecheck": "tsc -p tsconfig.ui.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@linear/sdk": "^39.0.0",
    "@octokit/rest": "^22.0.1",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "graphology": "^0.26.0",
    "graphology-dag": "^0.4.1",
    "graphology-traversal": "^0.3.1",
    "p-retry": "^6.2.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
